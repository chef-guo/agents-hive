{
  "_comment": "Docker 部署。容器内前缀固定为 /opt/hive/workdir（与 sessions_dir 一致）。宿主机路径：推荐 make docker-up（macOS→./.hive-workdir，Linux→/opt/hive/workdir）；直接 docker compose 默认 ./.hive-workdir。可用 HIVE_WORKDIR_HOST 覆盖。",

  "server": {
    "port": 18080,
    "host": "0.0.0.0",
    "cors_origins": []
  },

  "logging": {
    "level": "info",
    "format": "json",
    "file": "/data/logs/hive.log",
    "console_level": "info",
    "max_size": 100,
    "max_backups": 5,
    "max_age": 14
  },

  "store": {
    "type": "postgres",
    "postgres": {
      "host": "postgres",
      "port": 5432,
      "database": "claw",
      "user": "claw",
      "password": "${POSTGRES_PASSWORD}",
      "ssl_mode": "disable",
      "max_conns": 10
    }
  },

  "sessions_dir": "/opt/hive/workdir/sessions",
  "custom_tools_dir": "/data/tools",

  "asset": {
    "provider": "minio",
    "minio": {
      "endpoint": "minio:9000",
      "access_key": "${MINIO_ACCESS_KEY}",
      "secret_key": "${MINIO_SECRET_KEY}",
      "bucket": "${MINIO_BUCKET}",
      "region": "",
      "use_ssl": false
    },
    "local": {
      "base_path": "/data/assets"
    }
  },

  "sandbox": {
    "enabled": true,
    "type": "docker",
    "docker": {
      "image": "hive-sandbox:latest",
      "cpu_limit": "1.0",
      "memory_limit": "512m",
      "pids_limit": 100,
      "tmpfs_size": "256m",
      "network": "bridge",
      "network_disabled": false,
      "read_only_workdir": false
    }
  },

  "gateway": {
    "enabled": false,
    "tokens": []
  },

  "auth": {
    "_comment": "默认与仓库一致开启；生产请在编排层覆盖 frontend_url 为实际 Web 域名",
    "enabled": true,
    "frontend_url": ""
  },

  "webui": {
    "enabled": true
  }
}
